{
  "name": "@supramark/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:build": "bun run docs:generate && vitepress build",
    "docs:preview": "vitepress preview",
    "docs:generate": "bun run docs:generate:all",
    "docs:generate:all": "bun run docs:generate:features && bun run docs:generate:api && bun run docs:generate:examples && bun run docs:copy-typedoc",
    "docs:generate:features": "node ../scripts/generate-feature-docs.mjs",
    "docs:generate:api": "node ../scripts/generate-api-docs.mjs",
    "docs:generate:examples": "node ../scripts/generate-example-docs.mjs",
    "docs:copy-typedoc": "cp -r ../packages/core/docs/api ./public/typedoc"
  },
  "devDependencies": {
    "vitepress": "^1.0.0",
    "vue": "^3.4.0"
  }
}
